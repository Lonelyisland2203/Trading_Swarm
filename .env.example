# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_GENERATOR_MODEL=qwen3:8b
OLLAMA_CRITIC_MODEL=deepseek-r1:14b
OLLAMA_KEEP_ALIVE=0
OLLAMA_TIMEOUT=300

# Swarm Settings
GENERATOR_PERSONAS=3
CRITIQUE_ENABLED=true
DPO_BATCH_SIZE=4
TRAINING_ENABLED=false
CONCURRENCY=2

# Reward Weights for DPO Training (must sum to 1.0)
REWARD_RETURN_WEIGHT=0.50
REWARD_DIRECTIONAL_WEIGHT=0.30
REWARD_MAE_WEIGHT=0.20

# Market Data Settings
EXCHANGE=binance
SYMBOLS=BTC/USDT,ETH/USDT,BNB/USDT
TIMEFRAME=1h
LOOKBACK_BARS=100
DATA_CACHE_DIR=data/cache
DATA_CACHE_SIZE_LIMIT=1073741824

# Paths
MODEL_SAVE_DIR=models
OUTPUT_DIR=outputs
CACHE_DIR=.cache

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
